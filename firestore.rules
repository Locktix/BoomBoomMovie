rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Self-access: read + full write
      // Admin access: read any user (for /admin page), update admin flag
      allow read: if request.auth != null
        && (request.auth.uid == userId
            || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.admin == true);
      allow create, delete: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null
        && (request.auth.uid == userId
            || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.admin == true);
    }
    match /requests/{requestId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update: if request.auth != null
        && (resource.data.requestedBy == request.auth.uid
            || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.admin == true);
      allow delete: if request.auth != null
        && (resource.data.requestedBy == request.auth.uid
            || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.admin == true);
    }
    match /skipMarkers/{markerId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.admin == true;
    }
    match /watchParties/{roomCode} {
      // Any authenticated user can create or join a room
      allow read, create: if request.auth != null;
      // Any authenticated user can update (host for state, participants for join/leave)
      allow update: if request.auth != null;
      // Only the host can delete the room
      allow delete: if request.auth != null
        && resource.data.hostUid == request.auth.uid;

      // Chat messages — any auth participant can read+post; only the
      // sender can edit/delete their own message
      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.senderUid == request.auth.uid;
        allow update, delete: if request.auth != null
          && resource.data.senderUid == request.auth.uid;
      }

      // Ephemeral reactions — same rules as messages
      match /reactions/{reactionId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.senderUid == request.auth.uid;
        allow update, delete: if request.auth != null
          && resource.data.senderUid == request.auth.uid;
      }
    }
  }
}
